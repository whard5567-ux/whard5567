# Salin file ini jadi `.env.local` lalu isi nilainya (minta ke owner via japri).
# JANGAN pernah commit .env.local — sudah di-gitignore.
#   cp .env.example .env.local

# Koneksi Postgres Supabase via transaction pooler (port 6543).
# Untuk dev kolaborator Diagus dipakai role `ht2_diagus`:
#   CRUD penuh di schema hargi_ht2 SAJA — schema lain ditolak.
# Format: postgresql://ht2_diagus.<project-ref>:<password>@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres
DB_URL=

# URL project Supabase (untuk proxy /api/refresh → Edge Function)
SUPABASE_URL=https://mjgekmjnsipthcswazid.supabase.co

# Publishable key Supabase (bearer pemanggilan EF; memang didesain boleh tersebar)
SUPABASE_PUBLISHABLE_KEY=
